# Postgres connection string (Supabase session pooler for local/migrations)
DATABASE_URI=postgresql://user:password@host:5432/postgres
# Optional: transaction pooler used in serverless runtime
DATABASE_URI_TRANSACTION=postgresql://user:password@host:6543/postgres
# Payload CMS encryption secret (openssl rand -hex 32)
PAYLOAD_SECRET=
# Absolute URL of the site
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# First admin user, created by `pnpm seed` (leave blank to skip)
ADMIN_EMAIL=admin@woyable.com
ADMIN_PASSWORD=
